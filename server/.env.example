# Environment variables for CollectAI server
PORT=8080

#database connection string for local development
MONGO_URI=mongodb://mongo:27017/collectai

# For production, use a secure connection string with credentials, e.g.:
JWT_SECRET=your_jwt_secret_64_char_hex

# GROQ API key for Sanity CMS
GROQ_API_KEY =your_groq_api_key

# Email (Nodemailer) — use Gmail, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=CollectAI

# URL of your frontend application (for CORS and email links)
CLIENT_URL=url_of_your_frontend_app


#cashfree for payment gateway
CASHFREE_APP_ID=xxxx
CASHFREE_SECRET_KEY=xxxx

